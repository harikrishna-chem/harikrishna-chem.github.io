<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% if seoTitle %}
    {% set pageTitle = seoTitle %}
  {% elif title %}
    {% set pageTitle = title ~ " | " ~ site.name %}
  {% else %}
    {% set pageTitle = site.name %}
  {% endif %}
  {% set pageDescription = description or site.description %}
  {% set canonicalUrl = "https://" ~ site.domain ~ page.url %}
  {% set socialImage = "https://" ~ site.domain ~ "/assets/images/hari-photo_500.jpg" %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <link rel="canonical" href="{{ canonicalUrl }}">
  <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon/favicon-48.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicon/favicon-96.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/favicon/favicon-192.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
  <meta name="theme-color" content="#f6f1e8">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:image" content="{{ socialImage }}">
  <meta property="og:image:alt" content="Photo of {{ site.name }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ socialImage }}">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ site.name | json | safe }},
      "url": {{ ("https://" ~ site.domain ~ "/") | json | safe }}
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": {{ site.name | json | safe }},
      "url": {{ ("https://" ~ site.domain ~ "/") | json | safe }},
      "image": {{ socialImage | json | safe }},
      "jobTitle": {{ site.role | json | safe }},
      "affiliation": {
        "@type": "Organization",
        "name": {{ site.organization | json | safe }}
      },
      "sameAs": [
        {% for link in site.links %}
          {{ link.url | json | safe }}{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  </script>
  <link rel="stylesheet" href="/assets/css/site.css">
</head>
<body>
  <a class="skip-link" href="#content">Skip to content</a>
  <header class="site-header">
    <div class="site-header__inner">
      <a class="brand" href="/" aria-label="{{ site.name }} home">
        <img src="/assets/images/header_photo_transparent.png" alt="" width="64" height="64">
        <span>
          <strong>{{ site.name }}</strong>
          <small>{{ site.role }}</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        {% for item in site.nav %}
          <a class="site-nav__link{% if section == item.key %} is-active{% endif %}" href="{{ item.url }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>

  <main id="content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <p>&copy; {{ site.year }} {{ site.name }}</p>
      <div class="footer-links">
        {% for link in site.links %}
          <a href="{{ link.url }}">{{ link.label }}</a>
        {% endfor %}
        <a href="mailto:{{ site.email }}">Email</a>
      </div>
    </div>
  </footer>
</body>
</html>
