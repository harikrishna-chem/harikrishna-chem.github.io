---
layout: layouts/base.njk
title: Materials Informatics Engineer
description: Harikrishna Sahu is a Materials Informatics Engineer at Blue Origin working in materials informatics, polymer design, and machine learning.
section: home
---
<section class="hero">
  <div class="hero__text">
    <p class="eyebrow">Materials informatics / polymer ML / computational chemistry</p>
    <h1>Harikrishna Sahu</h1>
    <p class="lede">I build computational and machine-learning workflows that accelerate materials discovery, with recent work spanning polymer foundation models, physics-informed Gaussian Process Regression, autonomous structure generation, and data-driven design.</p>
    <div class="hero-actions">
      <a class="button" href="/research/">Research</a>
      <a class="button button--secondary" href="/writing/">Writing</a>
      <a class="button button--ghost" href="/cv/Harikrishna_Sahu.pdf">CV PDF</a>
    </div>
  </div>
  <figure class="portrait">
    <img src="/assets/images/hari-photo_500.jpg" srcset="/assets/images/hari-photo_1000.jpg 2x" alt="Photo of Harikrishna Sahu" width="500" height="515">
    <figcaption>{{ site.role }}, {{ site.organization }}</figcaption>
  </figure>
</section>

<section class="section-band">
  <div class="section-heading">
    <p class="eyebrow">Focus</p>
    <h2>Research and engineering themes</h2>
  </div>
  <div class="feature-grid">
    {% for project in projects | where("featured", true) | limit(3) %}
      <article class="feature-card">
        {% if project.type or project.status %}
          <div class="tag-row project-tags">
            {% if project.type %}<span>{{ project.type }}</span>{% endif %}
            {% if project.status %}<span>{{ project.status }}</span>{% endif %}
          </div>
        {% endif %}
        <p class="card-kicker">{{ project.subtitle }}</p>
        <h3>{{ project.title }}</h3>
        <p>{{ project.summary }}</p>
        <a class="text-link" href="/research/#{{ project.title | slugify }}">Read more</a>
      </article>
    {% endfor %}
  </div>
</section>

<section class="two-column">
  <div>
    <div class="section-heading">
      <p class="eyebrow">Selected work</p>
      <h2>Publications</h2>
    </div>
    <div class="publication-list compact">
      {% for publication in publications | where("selected", true) | limit(5) %}
        <article class="publication-item">
          <h3><a href="{{ publication.url }}">{{ publication.title }}</a></h3>
          <p>{{ publication.venue }}, {{ publication.year }}{% if publication.details %}, {{ publication.details }}{% endif %}</p>
        </article>
      {% endfor %}
    </div>
    <a class="text-link" href="/publications/">All publications</a>
  </div>
  <div>
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>Writing</h2>
    </div>
    <div class="post-list compact">
      {% for post in collections.posts | limit(3) %}
        <article class="post-item">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p>{{ post.data.summary }}</p>
        </article>
      {% endfor %}
    </div>
    <a class="text-link" href="/writing/">All writing</a>
  </div>
</section>
